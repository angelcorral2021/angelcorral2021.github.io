---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import Hero from "../components/sections/Hero.astro";
import ProjectCard from "../components/cards/ProjectCard.astro";

const profile = {
  name: "Angel Corral",
  title: "Ingeniero Informático & Pentester",
  country: "Chile",
  experience: "4 años",
  specialties: [
    "Pentesting",
    "Desarrollo Web",
    "Automatización",
    "Ciberseguridad",
    "DevSecOps"
  ],
};

const projects = [
  {
    title: "Proyectos",
    desc: "Explora mis desarrollos de software, arquitecturas e integraciones en múltiples tecnologías. Todo desde web hasta automatización industrial.",
    tags: ["php", "bash", "python", "n8n", "docker"],
    link: "/projects",
  },
  {
    title: "CTF-Writeups",
    desc: "Colección técnica de resoluciones de máquinas y desafíos de ciberseguridad. Estrategias de red team y explotación.",
    tags: ["writeups", "pentesting", "hacking"],
    link: "/writeups",
  },
];
---

<BaseLayout
  title="Angel Corral | Ciberseguridad & Desarrollo Web"
  description="Portafolio de Angel Corral, ingeniero informático especializado en ciberseguridad, automatización y desarrollo web con 4 años de experiencia."
>
  <Header slot="header" />
  
  <div class="flex flex-col gap-24">
    <!-- Hero Section -->
    <Hero profile={profile} />
    
    <!-- Proyectos Destacados -->
    <section class="animate-fade-in-up [animation-delay:200ms]">
      <div class="flex items-center gap-4 mb-10">
        <h2 class="text-3xl font-bold font-['Outfit'] text-slate-800 dark:text-white">Áreas Destacadas</h2>
        <div class="h-px bg-slate-200 dark:bg-slate-800 flex-1"></div>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8">
        {projects.map((p) => <ProjectCard {...p} />)}
      </div>
    </section>
  </div>
  
  <Footer slot="footer" />
</BaseLayout>
