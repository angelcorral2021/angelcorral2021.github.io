--- 
const { title, desc, tags, link } = Astro.props;
---
<a href={link} class="block h-full group">
  <div class="main-card h-full flex flex-col justify-between relative overflow-hidden">
    
    <!-- Efecto sutil de gradiente en hover -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

    <div class="relative z-10">
      <div class="flex items-start justify-between mb-4">
        <h3 class="font-bold text-xl font-['Outfit'] text-slate-800 dark:text-white group-hover:text-primary transition-colors">{title}</h3>
        <div class="w-8 h-8 rounded-full bg-slate-100 dark:bg-white/5 flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-all duration-300 group-hover:-translate-y-1 group-hover:translate-x-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
        </div>
      </div>
      
      <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-6">{desc}</p>
    </div>
    
    <div class="flex flex-wrap gap-2 mt-auto relative z-10">
      {tags.map((tag) => (
        <span class="px-2.5 py-1 text-[0.65rem] uppercase tracking-wider font-semibold rounded-full bg-slate-100 dark:bg-white/5 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-white/10 group-hover:border-primary/30 transition-colors">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
