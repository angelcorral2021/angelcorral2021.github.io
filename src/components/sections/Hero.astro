--- 
const { profile } = Astro.props;
---
<section class="grid lg:grid-cols-12 gap-12 items-center py-20 animate-fade-in-up">
  <div class="lg:col-span-7">

    <h1 class="text-5xl md:text-7xl font-bold font-['Outfit'] tracking-tight text-slate-800 dark:text-slate-100 leading-tight">
      Hola, soy <br/>
      <span class="bg-clip-text text-transparent bg-gradient-to-r from-primary via-secondary to-accent">
        {profile.name}
      </span>
    </h1>
    <h2 class="text-2xl md:text-3xl font-light tracking-wide text-slate-600 dark:text-slate-300 mt-4 font-['Outfit']">
      {profile.title}
    </h2>
    <p class="mt-6 text-slate-600 dark:text-slate-400 max-w-prose text-lg leading-relaxed">
      Ingeniero informático con <strong class="text-slate-800 dark:text-white font-medium">{profile.experience} de experiencia</strong>. Especializado en Ciberseguridad, análisis de sistemas, pentesting y desarrollo de software moderno. Construyendo soluciones seguras de extremo a extremo.
    </p>
    <div class="mt-10 flex flex-wrap gap-4">
      <a href="/projects" class="px-6 py-3 rounded-lg bg-gradient-to-r from-primary to-secondary hover:from-secondary hover:to-primary text-white font-medium shadow-[0_4px_20px_rgba(16,185,129,0.3)] hover:shadow-[0_6px_25px_rgba(16,185,129,0.5)] hover:-translate-y-0.5 transition-all duration-300">
        Ver Proyectos
      </a>
      <a href="/contact" class="px-6 py-3 rounded-lg border border-slate-300 dark:border-slate-700 hover:border-primary dark:hover:border-primary hover:bg-slate-50 dark:hover:bg-slate-800/50 text-slate-700 dark:text-slate-200 font-medium transition-all duration-300">
        Contactar
      </a>
    </div>
  </div>
  
  <div class="lg:col-span-5 animate-float">
    <div class="p-8 rounded-2xl main-card relative overflow-hidden group">
      <!-- Glow effect en el fondo de la card -->
      <div class="absolute -inset-1 bg-gradient-to-r from-primary to-secondary blur opacity-20 group-hover:opacity-40 transition duration-500 rounded-2xl"></div>
      
      <div class="relative bg-white dark:bg-[#0a0a0a] rounded-xl p-6 border border-slate-100 dark:border-white/5 h-full">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-lg font-['Outfit'] text-slate-800 dark:text-white">Perfil Técnico</h3>
            <div class="text-xs text-slate-500">{profile.country}</div>
          </div>
        </div>
        
        <div class="space-y-4">
          <div>
            <div class="text-xs text-slate-400 uppercase font-semibold tracking-wider mb-2">Especialidades principales</div>
            <div class="flex flex-wrap gap-2">
              {profile.specialties.map(spec => (
                <span class="px-2.5 py-1 text-xs rounded-md bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 text-slate-700 dark:text-slate-300 font-medium">{spec}</span>
              ))}
            </div>
          </div>
          <div class="pt-2 border-t border-slate-100 dark:border-white/5">
            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
              Experiencia sólida en desarrollo web, administración Linux, Bash, Python, Docker y bases de datos. Enfoque estratégico en hacking ético y protección de infraestructura crítica.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
