---
import "../styles/global.css";

const { title = "Portfolio", description = "Informático y Electronico" } =
  Astro.props;
---

<html lang="es" class="dark scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Angel Corral" />
    <meta
      name="keywords"
      content="ciberseguridad, hacking ético, pentesting, red team, desarrollo web"
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>

    <!-- Favicon -->
    <link
      type="image/png"
      sizes="96x96"
      rel="icon"
      href="/icons8-hacker-96.png"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Theme initialization script -->
    <script>
      (function () {
        const theme = localStorage.getItem("theme") || "dark";
        document.documentElement.classList.toggle("light", theme === "light");
        document.documentElement.classList.toggle("dark", theme === "dark");
      })();
    </script>
  </head>
  <body class="bg-bg1 text-slate-200 font-sans antialiased selection:bg-primary/30 selection:text-primary-50">
    <!-- Efecto de malla de fondo sutil -->
    <div class="fixed inset-0 z-[-1] h-full w-full bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px] opacity-[0.03] dark:bg-[radial-gradient(#ffffff_1px,transparent_1px)]"></div>
    
    <div class="min-h-screen flex flex-col relative z-0">
      <slot name="header" />
      <main class="container mx-auto px-6 py-12 flex-1 max-w-5xl animate-fade-in-up">
        <slot />
      </main>
      <slot name="footer" />
    </div>
  </body>
</html>
